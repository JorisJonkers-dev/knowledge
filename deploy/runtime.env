DEPLOYMENT_ENVIRONMENT=runtime
SERVER_PORT=8080
DB_HOST=postgres.data-system.svc.cluster.local
DB_PORT=5432
DB_NAME=knowledge_db
RABBITMQ_HOST=rabbitmq.data-system.svc.cluster.local
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
INGEST_QUEUE=knowledge.ingest
INGEST_PREFETCH=4
LOG_LEVEL=INFO
VAULT_CLONE_DIR=/var/lib/knowledge-vault
VAULT_BRANCH=main
VAULT_SSH_KEY_PATH=/vault/secrets/id_ed25519
GIT_CONFIG_COUNT=1
GIT_CONFIG_KEY_0=safe.directory
GIT_CONFIG_VALUE_0=*
