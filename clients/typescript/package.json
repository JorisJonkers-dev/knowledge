{
  "name": "@jorisjonkers-dev/knowledge-api-client",
  "version": "0.1.0",
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "generate": "openapi-ts -f openapi-ts.config.ts",
    "build": "tsc -p tsconfig.json",
    "pack:dry-run": "corepack pnpm pack --pack-destination /tmp"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "typescript": "6.0.3"
  }
}
